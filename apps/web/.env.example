# Mock Service Worker (for local development)
NEXT_PUBLIC_USE_MSW=true

# CMS API URL
API_URL=http://localhost:3001/api

# Translations Configuration
# Set to 'true' to fetch translations from CMS, 'false' to use JSON files
NEXT_PUBLIC_USE_CMS_TRANSLATIONS=false

# CMS URL for translation fetching
NEXT_PUBLIC_CMS_URL=http://localhost:3001
