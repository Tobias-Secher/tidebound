{
  "name": "web",
  "version": "0.1.0",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "next dev --port 3000",
    "build": "next build",
    "start": "next start",
    "lint": "eslint --max-warnings 0",
    "check-types": "next typegen && tsc --noEmit",
    "test": "jest --passWithNoTests --maxWorkers=50%",
    "test:watch": "jest --watch --passWithNoTests --maxWorkers=25%",
    "test:coverage": "jest --coverage --passWithNoTests --maxWorkers=50%"
  },
  "dependencies": {
    "@repo/ui": "workspace:*",
    "@repo/mocks": "workspace:*",
    "@repo/utils": "workspace:*",
    "next": "catalog:",
    "react": "catalog:",
    "react-dom": "catalog:",
    "@tanstack/react-query": "catalog:"
  },
  "devDependencies": {
    "@repo/eslint-config": "workspace:*",
    "@repo/typescript-config": "workspace:*",
    "@repo/jest-config": "workspace:*",
    "@repo/services": "workspace:*",
    "@testing-library/jest-dom": "catalog:",
    "@testing-library/react": "catalog:",
    "@testing-library/user-event": "catalog:",
    "@types/jest": "catalog:",
    "@types/node": "catalog:",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "eslint": "catalog:",
    "jest": "catalog:",
    "jest-environment-jsdom": "catalog:",
    "msw": "catalog:",
    "typescript": "catalog:"
  },
  "msw": {
    "workerDirectory": [
      "public"
    ]
  }
}