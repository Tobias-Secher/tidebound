{
  "$schema": "https://turborepo.com/schema.json",
  "ui": "tui",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": [".next/**", "!.next/cache/**", "dist/**"]
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "check-types": {
      "dependsOn": ["^check-types"]
    },
    "test": {
      "inputs": [
        "src/**/*.{ts,tsx,js,jsx}",
        "app/**/*.{ts,tsx,js,jsx}",
        "jest.config.{js,cjs}",
        "**/__tests__/**",
        "**/*.{test,spec}.{ts,tsx,js,jsx}"
      ]
    },
    "test:coverage": {
      "inputs": [
        "src/**/*.{ts,tsx,js,jsx}",
        "app/**/*.{ts,tsx,js,jsx}",
        "jest.config.{js,cjs}",
        "**/__tests__/**",
        "**/*.{test,spec}.{ts,tsx,js,jsx}"
      ],
      "outputs": ["coverage/**"]
    },
    "generate:types": {
      "cache": false
    },
    "generate:translations": {
      "cache": false
    },
    "generate:component": {
      "cache": false,
      "interactive": true
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "storybook": {
      "cache": false,
      "persistent": true
    },
    "env-pull": {
      "cache": false,
      "interactive": true
    },
    "generate:importmap": {
      "dependsOn": ["@repo/api-types#build"],
      "cache": false
    },
    "build-storybook": {
      "dependsOn": ["^build"],
      "outputs": ["storybook-static/**"]
    }
  },
  "globalEnv": ["NODE_ENV", "NEXT_PUBLIC_USE_MSW", "API_URL", "PAYLOAD_SECRET", "DATABASE_URI"]
}
